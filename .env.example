# Copy to .env and fill in. NEVER commit .env — it holds secrets.

# PurpleAir read API key — get one at https://develop.purpleair.com/
PURPLEAIR_API_KEY=

# Storage connection string. Defaults to a local SQLite file if unset.
# Production target: postgresql://user:pass@host:5432/airwv
AIRWV_DATABASE_URL=

# Collection interval in seconds. PurpleAir charges API points per sensor per
# call, so tight intervals across many sensors get expensive fast. Default 3600
# (hourly) is sustainable on the free 1M-point tier for ~30 sensors.
AIRWV_POLL_INTERVAL_SECONDS=3600

# Where to cache the private device_id -> PurpleAir sensor_index map.
# Defaults to data/sensor_index_map.json (gitignored). Optional.
AIRWV_INDEX_CACHE=

# Optional — only needed later to add PRIVATE (non-public) sensors to a PurpleAir
# group by MAC. Public sensors resolve without these.
# PURPLEAIR_WRITE_KEY=
# PURPLEAIR_OWNER_EMAIL=

# OpenAQ API key — reference/regulatory-monitor data for validation.
# Free at https://explore.openaq.org/register . Optional.
# OPENAQ_API_KEY=
# HARD cap on OpenAQ requests/day — the app STOPS at this many and resumes the next
# day, so we never exceed the free-tier quota (over-quota bulk pulls get the key
# suspended). Confirm your account's actual daily limit and set this below it.
# OPENAQ_DAILY_CAP=1000

# Admin / moderation console token (X-Admin-Token header). Admin is DISABLED
# until this is set (fails closed). Use a long random value, e.g.
#   python -c "import secrets; print(secrets.token_urlsafe(24))"
# AIRWV_ADMIN_TOKEN=

# Chat notifications for new community reports & site feedback. Set either, both,
# or neither (disabled if unset). Incoming-webhook URLs — no bot/API key needed.
#   Discord: channel -> Integrations -> Webhooks -> New Webhook -> Copy URL
#   Slack:   https://api.slack.com/apps -> Incoming Webhooks -> Add to Workspace
# AIRWV_DISCORD_WEBHOOK_URL=
# AIRWV_SLACK_WEBHOOK_URL=
# Public base URL used for the "Review in admin" link in those pings.
# AIRWV_PUBLIC_URL=https://air.createwv.org
# Discord display name + avatar. By default reports post as "AirWV Reports" and
# feedback as "AirWV Feedback", with the site favicon as the avatar. Set a
# username to force ONE name for every message; set an avatar URL to override.
# AIRWV_DISCORD_USERNAME=
# AIRWV_DISCORD_AVATAR_URL=https://air.createwv.org/static/favicon.png

# Email (SMTP) for alert delivery. Fill in when ready to send email alerts;
# the 'log' channel works without these. Never commit real values.
# AIRWV_SMTP_HOST=smtp.example.com
# AIRWV_SMTP_PORT=587
# AIRWV_SMTP_USER=
# AIRWV_SMTP_PASSWORD=
# AIRWV_SMTP_FROM=alerts@createwv.org
# AIRWV_SMTP_TLS=1
